    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "iconsax-react-native": "^0.0.8",
    "nativewind": "^4.1.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-health-connect": "^3.4.1",
