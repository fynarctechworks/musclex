# Member BFF base URL (the /member/v1 surface inside the existing NestJS SaaS).
# Use your machine LAN IP (not localhost) when testing on a physical device.
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/member/v1

# Supabase project that fronts phone-OTP (the existing SaaS IdP).
# Staging project per project_member_bff_phase0 memory: use fake tenants only.
EXPO_PUBLIC_SUPABASE_URL=https://tcpchduxxqsjnsybegjz.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Analytics + JS error reporting (PostHog HTTP capture). Leave the key blank to
# keep analytics a no-op (dev console). Set the project key to activate.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# SCC Error Center ingest. When BOTH are set, caught JS errors are also reported
# to the SaaS Control Center (POST {url}/system-errors, x-ingest-key auth). URL is
# the SCC API base (no path). The key must match one of the SCC's INGEST_API_KEYS.
EXPO_PUBLIC_SCC_INGEST_URL=
EXPO_PUBLIC_SCC_INGEST_KEY=

# ⚠️ DEV-ONLY OTP bypass. When set, login skips Supabase SMS and uses this fixed
# code (must match the backend's MEMBER_DEV_OTP). Blank = real SMS OTP flow.
EXPO_PUBLIC_MEMBER_DEV_OTP=
