# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres?schema=scc"

# ─── Redis (Upstash) ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET="<generate-a-strong-secret>"
JWT_EXPIRY="15m"
JWT_REFRESH_SECRET="<generate-a-strong-refresh-secret>"
JWT_REFRESH_EXPIRY="7d"

# ─── App ─────────────────────────────────────────────────
PORT=4001
NODE_ENV="development"
API_PREFIX="api/v1"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ─── Super Admin Bootstrap ───────────────────────────────
SUPER_ADMIN_EMAIL="musclex@fynarctechworks.com"
SUPER_ADMIN_PASSWORD="MuscleX@Admin#2026!"

# ─── Main App Database (read-only connection) ────────────
MAIN_APP_DATABASE_URL="postgresql://postgres:password@localhost:5432/musclex_db?schema=public"

# ─── Rate Limiting ───────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# ─── Email (Resend) ──────────────────────────────────────
# Powers admin password-reset emails and critical-alert delivery.
# Without RESEND_API_KEY, SCC logs emails instead of sending (dev/CI) and the
# alert transport falls back to logging. From address must be on a verified
# domain (see docs/email-infrastructure/DNS_SETUP.md).
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=MuscleX SCC <noreply@mail.yourdomain.com>
# Base URL of the SCC frontend — used to build password-reset links.
SCC_FRONTEND_URL=http://localhost:3001
# Comma-separated recipients for critical system alerts (blank = no email alerts).
ALERT_EMAIL_TO=
