// PER-STUDIO SCHEMA — Document engine (PDF + delivery)
// =============================================

model Document {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String   @db.Uuid
  branch_id       String?  @db.Uuid
  // Polymorphic owner: invoice | pos_sale | refund
  source_type     String
  source_id       String   @db.Uuid
  // tax_invoice (GST) | invoice | receipt | thermal_receipt | credit_note
  doc_type        String
  format          String   @default("a4") // a4 | thermal_80mm
  storage_bucket  String   @default("documents")
  storage_path    String // {gym_id}/{source_type}/{source_id}/{doc_id}.pdf
  size_bytes      Int      @default(0)
  checksum_sha256 String?
  // optional cached short-lived signed URL (we always regenerate on demand)
  status          String   @default("ready") // ready | generating | failed
  error           String?
  // Snapshot of issuer + buyer + line items at generation time (audit trail)
  payload         Json     @default("{}")
  // Invoice number embedded in the document (immutable copy)
  invoice_number  String?
  // Used to invalidate stale PDFs when underlying invoice changes
  version         Int      @default(1)
  generated_by    String?  @db.Uuid // staff id
  generated_at    DateTime @default(now()) @db.Timestamptz()

  // Polymorphic: no DB FK on source_id (source_type discriminates). Resolved in app code.
  deliveries DocumentDelivery[]

  @@index([source_type, source_id])
  @@index([gym_id, generated_at])
  @@index([status])
  @@map("documents")
  @@schema("studio_template")
}

model DocumentDelivery {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String    @db.Uuid
  document_id     String    @db.Uuid
  channel         String // email | whatsapp | sms | download
  recipient       String // email address or E.164 phone
  status          String    @default("queued") // queued | sent | failed | bounced
  provider        String? // resend | meta_whatsapp | twilio
  provider_msg_id String?
  error           String?
  attempts        Int       @default(0)
  sent_at         DateTime? @db.Timestamptz()
  created_at      DateTime  @default(now()) @db.Timestamptz()
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamptz()

  document Document @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id])
  @@index([status])
  @@index([channel, status])
  @@map("document_deliveries")
  @@schema("studio_template")
}

model FinancialTransaction {
