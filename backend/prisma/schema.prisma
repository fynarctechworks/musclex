model ConsentLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  member_id      String   @db.Uuid
  consent_type   String // marketing_email | marketing_sms | marketing_whatsapp | data_processing | facial_recognition | analytics | third_party_sharing
  granted        Boolean
  previous_value Boolean?
  ip_address     String?
