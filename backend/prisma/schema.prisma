model MemberReferral {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id             String    @db.Uuid
  referrer_member_id String    @db.Uuid
  referred_member_id String    @db.Uuid
  reward_status      String    @default("pending") // pending | awarded | expired
  reward_type        String? // discount | free_days | cash
  reward_value       Decimal?  @db.Decimal(10, 2)
  awarded_at         DateTime? @db.Timestamptz()
  created_at         DateTime  @default(now()) @db.Timestamptz()

  referrer Member @relation("Referrer", fields: [referrer_member_id], references: [id], onDelete: Cascade)
  referred Member @relation("Referred", fields: [referred_member_id], references: [id], onDelete: Cascade)

  @@unique([referrer_member_id, referred_member_id])
  @@index([referrer_member_id])
  @@index([referred_member_id])
  @@map("member_referrals")
  @@schema("studio_template")
}

model MembershipPlan {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id                 String   @db.Uuid
  organization_id        String?  @db.Uuid
  branch_id              String?  @db.Uuid
  name                   String
  description            String?
  plan_type              String // monthly | quarterly | half_yearly | yearly | class_pack | custom | day_pass | corporate | family | global_access
  duration_days          Int?
  total_classes          Int?
  max_classes_per_week   Int?
  max_visits             Int? // for visit-based plans
  price                  Decimal  @db.Decimal(10, 2)
  yearly_price           Decimal? @db.Decimal(10, 2)
  currency               String   @default("INR")
  multi_branch_access    Boolean  @default(false) // legacy boolean; superseded by access_type. kept for backward compat
  // ── Multi-gym access scope (Phase 1 of cross-branch architecture) ──
  // single_branch  : home branch only (legacy default)
  // multi_branch   : allowlist via allowed_branch_ids / MembershipBranchAccess
  // all_access     : every branch under the organization
  // city_access    : every branch in allowed_city
  // time_based     : restricted to allowed_hours_json window
  // class_only     : class bookings only, no open-gym access
  access_type            String   @default("single_branch")
  tier                   String   @default("basic") // basic | pro | elite | vip
  allowed_branch_ids     String[] @default([]) @db.Uuid // used when access_type=multi_branch
  allowed_city           String? // used when access_type=city_access
  allowed_hours_json     Json? // { "start": "06:00", "end": "10:00", "days": [1,2,3,4,5] }
  feature_flags          Json     @default("{}") // { "personal_training": true, "spa": false, "guest_passes": 2 }
  branch_price_overrides Json     @default("{}") // { "<branch_id>": 1499.00 }
  grace_period_days      Int      @default(0) // days after expiry before full lockout
  is_active              Boolean  @default(true)
  auto_renew_enabled     Boolean  @default(false)
  created_at             DateTime @default(now()) @db.Timestamptz()
  updated_at             DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization         Organization?         @relation(fields: [organization_id], references: [id])
  branch               Branch?               @relation(fields: [branch_id], references: [id])
  memberships          MemberMembership[]
  family_memberships   FamilyMembership[]
  global_access_passes GlobalAccessPass[]
  membership_analytics MembershipAnalytics[]

  @@index([organization_id])
  @@index([plan_type])
  @@index([access_type])
  @@index([tier])
  @@map("membership_plans")
  @@schema("studio_template")
}

model MemberMembership {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id               String    @db.Uuid
  member_id            String    @db.Uuid
  plan_id              String    @db.Uuid
  branch_id            String    @db.Uuid
  start_date           DateTime  @db.Date
  end_date             DateTime? @db.Date
  classes_remaining    Int?
  remaining_visits     Int? // for visit-based plans
  status               String    @default("active") // pending | active | paused | frozen | expired | cancelled | renewed
  freeze_start_date    DateTime? @db.Date
  freeze_end_date      DateTime? @db.Date
  freeze_reason        String?
  grace_end_date       DateTime? @db.Date // end of grace period after expiry
  auto_renew           Boolean   @default(false)
  payment_method_token String?
  created_at           DateTime  @default(now()) @db.Timestamptz()
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz()

  member            Member                   @relation(fields: [member_id], references: [id])
  plan              MembershipPlan           @relation(fields: [plan_id], references: [id])
  branch            Branch                   @relation(fields: [branch_id], references: [id])
  check_ins         CheckIn[]
  payments          Payment[]
  freezes           MembershipFreeze[]
  family_membership FamilyMembership?
  corporate_members CorporateMember[]
  branch_access     MembershipBranchAccess[]

  @@index([member_id, status])
  @@index([status, end_date])
  @@index([auto_renew, status])
  @@map("member_memberships")
  @@schema("studio_template")
}

// ── Multi-Branch Access (Phase 1 of cross-branch architecture) ─────────
// Normalized join replacing GlobalAccessPass.allowed_branch_ids array scans.
// Backfilled 1:1 from existing memberships so single_branch behavior is preserved.
// expires_at supports temporary access (e.g. 7-day travel pass for an elite member).

model MembershipBranchAccess {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id        String    @db.Uuid
  membership_id String    @db.Uuid
  branch_id     String    @db.Uuid
  granted_at    DateTime  @default(now()) @db.Timestamptz()
  granted_by    String?   @db.Uuid // staff/user who granted; null for system backfill
  expires_at    DateTime? @db.Timestamptz() // null = no expiry; set for temporary guest/travel passes
  reason        String? // free text — "travel pass", "promotional upgrade", etc.
  created_at    DateTime  @default(now()) @db.Timestamptz()

  membership MemberMembership @relation(fields: [membership_id], references: [id], onDelete: Cascade)
  branch     Branch           @relation(fields: [branch_id], references: [id])

  @@unique([membership_id, branch_id])
  @@index([branch_id, expires_at])
  @@index([membership_id])
  @@map("membership_branch_access")
  @@schema("studio_template")
}

// ── Member Branch Transfer Audit (Phase 4) ─────────────────────────────
// Append-only history of home-branch transfers. We deliberately do NOT
// touch existing memberships when transferring — they stay bound to their
// original branch for revenue attribution; only Member.branch_id flips.

model MemberTransferLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id         String   @db.Uuid
  member_id      String   @db.Uuid
  from_branch_id String   @db.Uuid
  to_branch_id   String   @db.Uuid
  reason         String?
  transferred_by String?  @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz()

  @@index([member_id, created_at])
  @@index([to_branch_id, created_at])
  @@map("member_transfer_logs")
  @@schema("studio_template")
}

// ── Membership Freeze History ─────────────────────────────────

model MembershipFreeze {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id         String    @db.Uuid
  membership_id  String    @db.Uuid
  start_date     DateTime  @db.Date
  end_date       DateTime? @db.Date
  reason         String?
  approved_by_id String?   @db.Uuid
  days_frozen    Int       @default(0)
  status         String    @default("active") // active | completed | cancelled
  created_at     DateTime  @default(now()) @db.Timestamptz()

  membership  MemberMembership @relation(fields: [membership_id], references: [id], onDelete: Cascade)
  approved_by Staff?           @relation(fields: [approved_by_id], references: [id])

  @@index([membership_id])
  @@map("membership_freezes")
  @@schema("studio_template")
}

// ── Family Membership ─────────────────────────────────────────

model FamilyMembership {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
