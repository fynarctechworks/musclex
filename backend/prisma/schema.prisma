  @@index([branch_id, period_type, period_key])
  @@map("expense_metrics")
  @@schema("studio_template")
}

model NotificationLog {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  member_id           String?  @db.Uuid
  channel             String
  trigger_type        String
  message_body        String
  status              String   @default("sent")
  external_message_id String?
  sent_at             DateTime @default(now()) @db.Timestamptz()

  member Member? @relation(fields: [member_id], references: [id])

  @@index([member_id])
  @@index([status])
  @@index([sent_at])
  @@map("notifications_log")
  @@schema("studio_template")
}

// In-app notifications targeted at a platform user (staff/owner), as opposed
// to NotificationLog which records outbound member messages (SMS/WhatsApp/email).
model Notification {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String    @db.Uuid
  user_id             String    @db.Uuid
  type                String // leave_request | leave_reviewed | ...
  title               String
  message             String
  data                Json      @default("{}")
  related_entity_id   String?   @db.Uuid
  related_entity_type String?
  is_read             Boolean   @default(false)
  read_at             DateTime? @db.Timestamptz()
  created_at          DateTime  @default(now()) @db.Timestamptz()

  @@index([gym_id, user_id, is_read])
  @@index([created_at])
  @@map("notifications")
  @@schema("studio_template")
}

// Pre-computed dashboard counters maintained by the event projector for
// fast reads. One row per (gym_id, branch_id); branch_id=null is the gym-wide
// rollup. `version` + `last_event_id` track projection progress (0 = unbuilt).
model DashboardMetrics {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id               String   @db.Uuid
  branch_id            String?  @db.Uuid
  total_members        Int      @default(0)
  active_members       Int      @default(0)
  total_staff          Int      @default(0)
  active_staff         Int      @default(0)
  monthly_revenue      Decimal  @default(0) @db.Decimal(12, 2)
  total_revenue        Decimal  @default(0) @db.Decimal(14, 2)
  check_ins_today      Int      @default(0)
  check_ins_month      Int      @default(0)
  expiring_memberships Int      @default(0)
  revenue_month        String? // 'yyyy-mm' the monthly_revenue figure applies to
  version              BigInt   @default(0)
  last_event_id        String?  @db.Uuid
  last_synced_at       DateTime @default(now()) @db.Timestamptz()
  created_at           DateTime @default(now()) @db.Timestamptz()
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz()

  branch Branch? @relation(fields: [branch_id], references: [id])

  @@unique([gym_id, branch_id], name: "gym_id_branch_id")
  @@map("dashboard_metrics")
  @@schema("studio_template")
}

model Campaign {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String    @db.Uuid
  name                String
  segment             String
  segment_filters     Json?
  channels            String[]
  message_template    String
  status              String    @default("draft")
  scheduled_at        DateTime? @db.Timestamptz()
  sent_count          Int       @default(0)
  delivered_count     Int       @default(0)
  created_by_staff_id String    @db.Uuid
  created_at          DateTime  @default(now()) @db.Timestamptz()

  created_by         Staff                     @relation(fields: [created_by_staff_id], references: [id])
  audience           CampaignAudience[]
  campaign_analytics CampaignAnalyticsRecord[]

  @@index([status])
  @@index([created_by_staff_id])
  @@index([scheduled_at])
  @@map("campaigns")
  @@schema("studio_template")
}

// =============================================
// PER-STUDIO SCHEMA — Marketing & Automation Engine
// =============================================

model Lead {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  organization_id     String?  @db.Uuid
  branch_id           String?  @db.Uuid
  full_name           String
  email               String?
  phone               String?
  lead_source         String // website | instagram | facebook_ads | walk_in | referral | google_ads
  status              String   @default("new") // new | contacted | trial_scheduled | converted | lost
  assigned_staff_id   String?  @db.Uuid
  notes               String?
  converted_member_id String?  @db.Uuid
  created_at          DateTime @default(now()) @db.Timestamptz()
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization     Organization?  @relation(fields: [organization_id], references: [id])
  branch           Branch?        @relation(fields: [branch_id], references: [id])
  assigned_staff   Staff?         @relation("LeadAssignedStaff", fields: [assigned_staff_id], references: [id])
  converted_member Member?        @relation("LeadConvertedMember", fields: [converted_member_id], references: [id])
  activities       LeadActivity[]

  @@index([organization_id])
  @@index([branch_id])
  @@index([status])
  @@index([lead_source])
  @@index([assigned_staff_id])
  @@index([assigned_staff_id, status])
  @@index([created_at])
  @@map("leads")
  @@schema("studio_template")
}

model LeadActivity {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id        String   @db.Uuid
  lead_id       String   @db.Uuid
  staff_id      String?  @db.Uuid
  activity_type String // call | email | visit | trial_booking | note | status_change
  notes         String?
  created_at    DateTime @default(now()) @db.Timestamptz()

  lead  Lead   @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  staff Staff? @relation("LeadActivityStaff", fields: [staff_id], references: [id])

  @@index([lead_id])
  @@index([staff_id])
  @@index([created_at])
  @@map("lead_activities")
  @@schema("studio_template")
}

model CampaignAudience {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id      String    @db.Uuid
  campaign_id String    @db.Uuid
  member_id   String    @db.Uuid
  status      String    @default("pending") // pending | sent | delivered | opened | clicked | bounced
  sent_at     DateTime? @db.Timestamptz()
  opened_at   DateTime? @db.Timestamptz()
  clicked_at  DateTime? @db.Timestamptz()

  campaign Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [member_id], references: [id])

  @@unique([campaign_id, member_id])
  @@index([campaign_id])
  @@index([member_id])
  @@index([status])
  @@map("campaign_audience")
  @@schema("studio_template")
}

model MessageTemplate {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String   @db.Uuid
  organization_id String?  @db.Uuid
  template_name   String
  channel         String // email | sms | whatsapp | push_notification
  subject         String?
  content         String
  variables       String[] // e.g., ["member_name", "expiry_date", "plan_name"]
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization     Organization?    @relation(fields: [organization_id], references: [id])
  workflow_actions WorkflowAction[]

  @@index([organization_id])
  @@index([channel])
  @@map("message_templates")
  @@schema("studio_template")
}

model AutomationWorkflow {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String   @db.Uuid
  organization_id String?  @db.Uuid
  workflow_name   String
  trigger_event   String // membership_expiring | member_inactive | lead_created | class_missed | birthday | payment_failed
  trigger_config  Json? // e.g., {"days_before_expiry": 7}
  status          String   @default("active") // active | paused | archived
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization Organization?    @relation(fields: [organization_id], references: [id])
  actions      WorkflowAction[]

  @@index([organization_id])
  @@index([trigger_event])
  @@index([status])
  @@map("automation_workflows")
  @@schema("studio_template")
}

model WorkflowAction {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id        String   @db.Uuid
  workflow_id   String   @db.Uuid
  action_order  Int      @default(1)
  action_type   String // send_email | send_sms | send_whatsapp | send_push | assign_task | update_status
  delay_minutes Int      @default(0)
  template_id   String?  @db.Uuid
  action_config Json? // extra config per action type
  created_at    DateTime @default(now()) @db.Timestamptz()

  workflow AutomationWorkflow @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  template MessageTemplate?   @relation(fields: [template_id], references: [id])

  @@index([workflow_id])
  @@index([template_id])
  @@map("workflow_actions")
  @@schema("studio_template")
}

model ReferralProgram {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String    @db.Uuid
  organization_id String?   @db.Uuid
  program_name    String
  reward_type     String // discount | free_days | cash | free_class
  reward_value    Decimal   @db.Decimal(10, 2)
  min_referrals   Int       @default(1)
  max_rewards     Int?
  status          String    @default("active") // active | paused | ended
  start_date      DateTime? @db.Timestamptz()
  end_date        DateTime? @db.Timestamptz()
  created_at      DateTime  @default(now()) @db.Timestamptz()
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamptz()

  organization Organization? @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([status])
  @@map("referral_programs")
  @@schema("studio_template")
}

model PushNotification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id     String    @db.Uuid
  member_id  String    @db.Uuid
  title      String
  message    String
  data       Json?
  status     String    @default("pending") // pending | sent | delivered | failed
  sent_at    DateTime? @db.Timestamptz()
  read_at    DateTime? @db.Timestamptz()
  created_at DateTime  @default(now()) @db.Timestamptz()

  member Member @relation(fields: [member_id], references: [id])

  @@index([member_id])
  @@index([status])
  @@index([created_at])
  @@map("push_notifications")
  @@schema("studio_template")
}

// =============================================
// PER-STUDIO SCHEMA — Inventory & POS
// =============================================

model ProductCategory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String   @db.Uuid
  organization_id String?  @db.Uuid
  name            String
  description     String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization Organization? @relation(fields: [organization_id], references: [id])
  products     Product[]

  @@map("product_categories")
  @@schema("studio_template")
}

model Product {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String   @db.Uuid
  organization_id String?  @db.Uuid
  branch_id       String?  @db.Uuid
  category_id     String?  @db.Uuid
  product_name    String
  description     String?
  // Phase 3: SKU/barcode unique PER gym (shared catalog), not globally — same SKU
  // can legitimately recur across separate studios in the same template schema.
  sku             String?  @db.VarChar(255)
  barcode         String?  @db.VarChar(255)
  price           Decimal  @db.Decimal(10, 2) // default/base price; per-branch overrides in branch_product_prices
  cost_price      Decimal  @default(0) @db.Decimal(10, 2)
  tax_rate        Decimal  @default(0) @db.Decimal(5, 2)
  image_url       String?
  status          String   @default("active") // active | inactive | discontinued
  // Phase 2: enterprise product attributes
  product_type    String   @default("physical") // physical | digital | service | subscription | consumable
  brand           String?
  unit_type       String? // e.g. piece | kg | g | litre | ml | pack
  track_batches   Boolean  @default(false) // when true, stock is sourced FIFO from product_batches
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization           Organization?          @relation(fields: [organization_id], references: [id])
  branch                 Branch?                @relation(fields: [branch_id], references: [id])
  category               ProductCategory?       @relation(fields: [category_id], references: [id])
  inventory              Inventory[] // one row per branch
  inventory_transactions InventoryTransaction[]
  pos_sale_items         PosSaleItem[]
  purchase_order_items   PurchaseOrderItem[]
  product_returns        ProductReturn[]
  batches                ProductBatch[]
  branch_prices          BranchProductPrice[]
  transfer_items         StockTransferItem[]
  bundle_items           BundleItem[]
  images                 ProductImage[]

  @@unique([gym_id, sku], map: "uq_products_gym_sku")
  @@unique([gym_id, barcode], map: "uq_products_gym_barcode")
  @@index([organization_id])
  @@index([branch_id])
  @@index([category_id])
  @@index([sku])
  @@index([barcode])
  @@index([status])
  @@index([product_type])
  @@map("products")
  @@schema("studio_template")
}

model ProductImage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id     String   @db.Uuid
  product_id String   @db.Uuid
  image_url  String
  alt_text   String?
  sort_order Int      @default(0)
  is_primary Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([gym_id])
  @@map("product_images")
  @@schema("studio_template")
}

model ProductBatch {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id       String    @db.Uuid
  product_id   String    @db.Uuid
  branch_id    String    @db.Uuid
  batch_number String
  quantity     Int       @default(0) // remaining quantity in this batch
  cost_price   Decimal   @default(0) @db.Decimal(10, 2)
  expiry_date  DateTime? @db.Date
  received_at  DateTime  @default(now()) @db.Timestamptz()
  supplier_id  String?   @db.Uuid
  status       String    @default("active") // active | depleted | expired
  created_at   DateTime  @default(now()) @db.Timestamptz()
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamptz()

  product        Product             @relation(fields: [product_id], references: [id], onDelete: Cascade)
  branch         Branch              @relation(fields: [branch_id], references: [id])
  pos_sale_items PosSaleItem[]
  transfer_items StockTransferItem[]

  // FIFO selection scans active batches for a product+branch ordered by expiry (NULLS LAST).
  @@index([product_id, branch_id, status, expiry_date])
  @@index([gym_id, status, expiry_date]) // expiring-soon alerts across branches
  @@index([product_id])
  @@map("product_batches")
  @@schema("studio_template")
}

// Per-branch price/tax override. When absent for a (product, branch), POS falls back
// to Product.price / Product.tax_rate. Enables independent pricing per branch/franchise.
model BranchProductPrice {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id     String   @db.Uuid
  product_id String   @db.Uuid
  branch_id  String   @db.Uuid
  price      Decimal  @db.Decimal(10, 2)
  tax_rate   Decimal? @db.Decimal(5, 2) // null = inherit product tax_rate
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branch_id], references: [id])

  @@unique([product_id, branch_id])
  @@index([branch_id])
  @@map("branch_product_prices")
  @@schema("studio_template")
}

// Branch-to-branch stock transfer. Lifecycle: pending -> in_transit -> received
// (or cancelled). Stock leaves source on dispatch, arrives at destination on receive.
model StockTransfer {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String    @db.Uuid
  transfer_number String    @unique // TRF-YYYYMMDD-XXXX
  from_branch_id  String    @db.Uuid
  to_branch_id    String    @db.Uuid
  status          String    @default("pending") // pending | in_transit | received | cancelled
  notes           String?
  initiated_by    String?   @db.Uuid
  received_by     String?   @db.Uuid
  dispatched_at   DateTime? @db.Timestamptz()
  received_at     DateTime? @db.Timestamptz()
  created_at      DateTime  @default(now()) @db.Timestamptz()
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamptz()

  from_branch Branch              @relation("TransferFrom", fields: [from_branch_id], references: [id])
  to_branch   Branch              @relation("TransferTo", fields: [to_branch_id], references: [id])
  items       StockTransferItem[]

  @@index([from_branch_id, created_at])
  @@index([to_branch_id, created_at])
  @@index([status])
  @@index([transfer_number])
  @@map("stock_transfers")
  @@schema("studio_template")
}

model StockTransferItem {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String    @db.Uuid
  transfer_id     String    @db.Uuid
  product_id      String    @db.Uuid
  // For batch-tracked products, the source batch this line moves (preserves expiry).
  source_batch_id String?   @db.Uuid
  batch_number    String?
  expiry_date     DateTime? @db.Date
  quantity        Int
  created_at      DateTime  @default(now()) @db.Timestamptz()

  transfer     StockTransfer @relation(fields: [transfer_id], references: [id], onDelete: Cascade)
  product      Product       @relation(fields: [product_id], references: [id])
  source_batch ProductBatch? @relation(fields: [source_batch_id], references: [id])

  @@index([transfer_id])
  @@index([product_id])
  @@map("stock_transfer_items")
  @@schema("studio_template")
}

// ── Wallet & Loyalty (Phase 4) ──────────────────────────────────
// Member stored-value wallet + loyalty points. One wallet per member.
model Wallet {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id         String   @db.Uuid
  member_id      String   @unique @db.Uuid
  balance        Decimal  @default(0) @db.Decimal(10, 2) // stored money value
  points_balance Int      @default(0) // loyalty points
  created_at     DateTime @default(now()) @db.Timestamptz()
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz()

  member       Member              @relation(fields: [member_id], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([gym_id])
  @@map("wallets")
  @@schema("studio_template")
}

// Append-only ledger for every wallet movement (money and/or points).
model WalletTransaction {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id         String   @db.Uuid
  wallet_id      String   @db.Uuid
  // topup | purchase | refund | points_earn | points_redeem | cashback | adjustment
  type           String
  amount         Decimal  @default(0) @db.Decimal(10, 2) // money delta (+credit / -debit)
  points         Int      @default(0) // points delta (+earn / -redeem)
  balance_after  Decimal  @db.Decimal(10, 2)
  points_after   Int
  reference_id   String?  @db.Uuid // e.g. pos_sale id
  reference_type String? // e.g. 'pos_sale'
  notes          String?
  created_by     String?  @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz()

  wallet Wallet @relation(fields: [wallet_id], references: [id], onDelete: Cascade)

  @@index([wallet_id, created_at])
  @@index([type])
  @@index([reference_id])
  @@map("wallet_transactions")
  @@schema("studio_template")
}

// Per-gym loyalty economics. Single active row per gym.
model LoyaltyConfig {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id                 String   @unique @db.Uuid
  is_active              Boolean  @default(false)
  points_per_currency    Decimal  @default(1) @db.Decimal(10, 4) // points earned per 1 currency spent
  redeem_value_per_point Decimal  @default(1) @db.Decimal(10, 4) // currency value of 1 point on redeem
  min_redeem_points      Int      @default(0)
  created_at             DateTime @default(now()) @db.Timestamptz()
  updated_at             DateTime @default(now()) @updatedAt @db.Timestamptz()

  @@map("loyalty_configs")
  @@schema("studio_template")
}

// ── Bundles (Phase 5) ───────────────────────────────────────────
// A bundle is a sellable composite — its own price independent of component sums.
// Selling deducts each component's stock (FIFO if batch-tracked). Per-component
// revenue is the proportional split of the bundle price by component list price.
model Bundle {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String   @db.Uuid
  organization_id String?  @db.Uuid
  branch_id       String?  @db.Uuid // null = available at all branches
  name            String
  description     String?
  sku             String?
  price           Decimal  @db.Decimal(10, 2) // own price; can be less than component sum
  tax_rate        Decimal  @default(0) @db.Decimal(5, 2)
  image_url       String?
  status          String   @default("active") // active | inactive | discontinued
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz()

  branch         Branch?       @relation(fields: [branch_id], references: [id])
  items          BundleItem[]
  pos_sale_items PosSaleItem[]

  @@unique([gym_id, sku], map: "uq_bundles_gym_sku")
  @@index([branch_id])
  @@index([status])
  @@map("bundles")
  @@schema("studio_template")
}

model BundleItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id     String   @db.Uuid
  bundle_id  String   @db.Uuid
  product_id String   @db.Uuid
  quantity   Int      @default(1)
  created_at DateTime @default(now()) @db.Timestamptz()

  bundle  Bundle  @relation(fields: [bundle_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id])

  @@unique([bundle_id, product_id]) // a product appears at most once per bundle
  @@index([bundle_id])
  @@index([product_id])
  @@map("bundle_items")
  @@schema("studio_template")
}

model Inventory {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id            String   @db.Uuid
  product_id        String   @db.Uuid
  branch_id         String   @db.Uuid
  stock_quantity    Int      @default(0)
  reserved_quantity Int      @default(0)
  reorder_level     Int      @default(5)
  last_updated      DateTime @default(now()) @db.Timestamptz()

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branch_id], references: [id])

  // One stock row per product PER branch (shared catalog, per-branch stock).
  @@unique([product_id, branch_id])
  @@index([branch_id])
  @@index([product_id])
  @@map("inventory")
  @@schema("studio_template")
}

model InventoryTransaction {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id           String   @db.Uuid
  product_id       String   @db.Uuid
  branch_id        String   @db.Uuid
  transaction_type String // purchase | sale | adjustment | return | damage
  quantity         Int
  reference_id     String?  @db.Uuid
  notes            String?
