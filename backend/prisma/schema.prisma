generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "studio_template"]
}

// =============================================
// PUBLIC SCHEMA — Tenant Registry
// =============================================

model Studio {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  slug                    String    @unique
  schema_name             String    @unique
  owner_user_id           String    @db.Uuid
  logo_url                String?
  tagline                 String?
  phone                   String?
  email                   String?
  website                 String?
  address                 String?
  city                    String?
  state                   String?
  country                 String?
  postal_code             String?
  business_name           String?
  business_type           String?
  timezone                String    @default("Asia/Kolkata")
  currency                String    @default("INR")
  subscription_plan       String    @default("free")
  subscription_status     String    @default("trial")
  billing_cycle           String    @default("monthly")
  billing_name            String?
  billing_email           String?
  billing_address         String?
  tax_id                  String?
  subscription_start      DateTime? @db.Timestamptz()
  next_billing_date       DateTime? @db.Timestamptz()
  trial_ends_at           DateTime? @db.Timestamptz()
  subscription_expires_at DateTime? @db.Timestamptz() // hard expiry; reward engine extends this
  // ── Subscription lifecycle (computed by SubscriptionPolicyService) ──
  // active | grace_period | locked | suspended
  lifecycle_status        String    @default("active")
  grace_until             DateTime? @db.Timestamptz() // last second of grace; null when ACTIVE
  locked_at               DateTime? @db.Timestamptz() // when LOCKED transition happened
  suspended_at            DateTime? @db.Timestamptz() // manual admin suspension
  last_status_computed_at DateTime? @db.Timestamptz()
  last_login_at           DateTime? @db.Timestamptz()
  two_factor_enabled      Boolean   @default(false)
  email_verified          Boolean   @default(false)
  phone_verified          Boolean   @default(false)
  account_type            String    @default("gym")
  // ── GST / tax-invoice settings (India) ──
  gstin                   String?
  gst_state_code          String? // 2-digit numeric, e.g. "27" for Maharashtra
  default_hsn             String?
  invoice_prefix          String?
  invoice_terms           String?
  referral_code           String    @unique
  referred_by_code        String?
  referral_free_days      Int       @default(0)
  referral_reward_days    Int       @default(0)
  created_at              DateTime  @default(now()) @db.Timestamptz()
  updated_at              DateTime  @default(now()) @updatedAt @db.Timestamptz()

  invoices            Invoice[]
  subscription_events SubscriptionEvent[]

  // ── Referral & Growth Engine relations ──
  referrals_sent    Referral[]            @relation("ReferrerStudio")
  referral_received Referral?             @relation("ReferredStudio")
  reward_logs       RewardLog[]           @relation("RewardBeneficiary")
  referral_wallet   ReferralWallet?
  fraud_signals     ReferralFraudSignal[] @relation("FraudSubjectStudio")

  @@index([lifecycle_status])
  @@index([next_billing_date])
  @@index([grace_until])
  @@index([subscription_expires_at])
  @@map("studios")
  @@schema("public")
}

model SubscriptionPlan {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String    @unique
  display_name        String
  description         String?
  monthly_price       Decimal   @db.Decimal(10, 2)
  annual_price        Decimal   @db.Decimal(10, 2)
  max_branches        Int       @default(1)
  max_members         Int       @default(100)
  max_staff           Int       @default(5)
  storage_limit_gb    Int       @default(1)
  api_access          Boolean   @default(false)
  features            Json      @default("{}") // { "multi_branch": true, ... }
  grace_days          Int       @default(3) // days after expiry before LOCKED
  plan_type           String    @default("regular")
  is_active           Boolean   @default(true)
  is_featured         Boolean   @default(false)
  sort_order          Int       @default(0)
  discount_percent    Decimal?  @db.Decimal(5, 2)
  discount_label      String?
  discount_expires_at DateTime? @db.Timestamptz()
  created_at          DateTime  @default(now()) @db.Timestamptz()
  updated_at          DateTime  @default(now()) @updatedAt @db.Timestamptz()

  @@map("subscription_plans")
  @@schema("public")
}

model Invoice {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studio_id            String    @db.Uuid
  invoice_number       String    @unique
  amount               Decimal   @db.Decimal(10, 2)
  currency             String    @default("INR")
  status               String    @default("pending") // pending | paid | failed | refunded
  billing_period_start DateTime  @db.Timestamptz()
  billing_period_end   DateTime  @db.Timestamptz()
  paid_at              DateTime? @db.Timestamptz()
  invoice_url          String?
  created_at           DateTime  @default(now()) @db.Timestamptz()

  studio Studio @relation(fields: [studio_id], references: [id])

  @@index([studio_id, created_at])
  @@map("invoices")
  @@schema("public")
}

// =============================================
// Subscription Event Ledger (immutable, append-only)
// Every lifecycle transition + billing action recorded here.
// Never UPDATE/DELETE — only INSERT.
// =============================================
model SubscriptionEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studio_id     String    @db.Uuid
  // created | renewed | plan_changed | entered_grace | locked | unlocked |
  // suspended | reactivated | payment_recorded | reminder_sent
  event_type    String
  from_status   String? // previous lifecycle_status (null on create)
  to_status     String? // new lifecycle_status
  plan_name     String? // plan in effect at event time
  billing_cycle String?
  amount        Decimal?  @db.Decimal(10, 2)
  currency      String?
  period_start  DateTime? @db.Timestamptz()
  period_end    DateTime? @db.Timestamptz()
  // who/what caused this — user_id for human action, "system" for cron, "webhook" for gateway
  actor_id      String?   @db.Uuid
  actor_type    String    @default("system") // system | user | webhook | admin
  // free-form context (invoice_id, gateway txn id, reminder channel, etc)
  metadata      Json      @default("{}")
  created_at    DateTime  @default(now()) @db.Timestamptz()

  studio Studio @relation(fields: [studio_id], references: [id])

  @@index([studio_id, created_at])
  @@index([studio_id, event_type])
  @@map("subscription_events")
  @@schema("public")
}

model EmailVerification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique
  expires_at DateTime @db.Timestamptz()
  used       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([user_id])
  @@index([token])
  @@map("email_verifications")
  @@schema("public")
}

model PendingRegistration {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name          String
  email              String
  phone              String?
  encrypted_password String
  token              String   @unique
  expires_at         DateTime @db.Timestamptz()
  created_at         DateTime @default(now()) @db.Timestamptz()

  @@index([email])
  @@index([token])
  @@map("pending_registrations")
  @@schema("public")
}

// =============================================
// PUBLIC SCHEMA — Identity & Session Management
// =============================================

model UserIdentity {
  id                      String    @id @db.Uuid // Same as Supabase Auth user ID
  email                   String    @unique
  full_name               String
  phone                   String?
  avatar_url              String?
  status                  String    @default("active") // active | suspended | deactivated
  email_verified          Boolean   @default(false)
  phone_verified          Boolean   @default(false)
  last_login_at           DateTime? @db.Timestamptz()
  login_count             Int       @default(0)
  failed_login_count      Int       @default(0)
  locked_until            DateTime? @db.Timestamptz()
  password_changed_at     DateTime? @db.Timestamptz()
  two_factor_enabled      Boolean   @default(false)
  two_factor_method       String? // totp | sms | email
  two_factor_secret       String? // encrypted TOTP secret
  two_factor_backup_codes String[]  @default([]) // hashed backup codes
  metadata                Json      @default("{}")
  created_at              DateTime  @default(now()) @db.Timestamptz()
  updated_at              DateTime  @default(now()) @updatedAt @db.Timestamptz()

  devices       UserDevice[]
  login_history LoginHistory[]
  sessions      UserSession[]
  user_roles    UserRole[]
  backup_codes  BackupCode[]

  @@index([email])
  @@index([status])
  @@map("user_identities")
  @@schema("public")
}

// Single-use 2FA backup codes (hashed). Supersedes the deprecated
// UserIdentity.two_factor_backup_codes array; one row per code so each can be
// individually marked used.
model BackupCode {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_identity_id String    @db.Uuid
  code_hash        String
  used_at          DateTime? @db.Timestamptz()
  created_at       DateTime  @default(now()) @db.Timestamptz()

  user UserIdentity @relation(fields: [user_identity_id], references: [id], onDelete: Cascade)

  @@index([user_identity_id, used_at])
  @@map("backup_codes")
  @@schema("public")
}

model UserDevice {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String   @db.Uuid
  device_fingerprint String
  device_name        String?
  device_type        String   @default("desktop") // mobile | desktop | tablet
  browser            String?
  os                 String?
  ip_address         String?
  location_city      String?
  location_country   String?
  is_trusted         Boolean  @default(false)
  last_active_at     DateTime @default(now()) @db.Timestamptz()
  created_at         DateTime @default(now()) @db.Timestamptz()

  user          UserIdentity   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  login_history LoginHistory[]
  sessions      UserSession[]

  @@unique([user_id, device_fingerprint])
  @@index([user_id])
  @@map("user_devices")
  @@schema("public")
}

model LoginHistory {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String?  @db.Uuid
  email          String
  ip_address     String?
  user_agent     String?
  device_id      String?  @db.Uuid
  login_method   String   @default("password") // password | sso | magic_link | refresh | api_key
  status         String // success | failed | blocked | locked
  failure_reason String?
  studio_id      String?  @db.Uuid
  metadata       Json?
  created_at     DateTime @default(now()) @db.Timestamptz()

  user   UserIdentity? @relation(fields: [user_id], references: [id], onDelete: SetNull)
  device UserDevice?   @relation(fields: [device_id], references: [id], onDelete: SetNull)

  @@index([user_id, created_at])
  @@index([email, created_at])
  @@index([ip_address])
  @@index([status, created_at])
  @@map("login_history")
  @@schema("public")
}

model UserSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  device_id        String?   @db.Uuid
  token_hash       String    @unique
  ip_address       String?
  studio_id        String?   @db.Uuid
  is_active        Boolean   @default(true)
  expires_at       DateTime  @db.Timestamptz()
  last_activity_at DateTime  @default(now()) @db.Timestamptz()
  revoked_at       DateTime? @db.Timestamptz()
  revoked_reason   String?
  created_at       DateTime  @default(now()) @db.Timestamptz()

  user   UserIdentity @relation(fields: [user_id], references: [id], onDelete: Cascade)
  device UserDevice?  @relation(fields: [device_id], references: [id], onDelete: SetNull)

  @@index([user_id, is_active])
  @@index([token_hash])
  @@index([expires_at])
  @@map("user_sessions")
  @@schema("public")
}

// =============================================
// PUBLIC SCHEMA — Normalized RBAC
// =============================================

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique // "members.create", "payments.view", etc.
  module      String // "members", "payments", "dashboard", etc.
  action      String // "view", "create", "edit", "delete", "export", "manage"
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz()

  @@index([module])
  @@map("permissions")
  @@schema("public")
}

model UserRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  studio_id   String   @db.Uuid
  branch_id   String?  @db.Uuid // null = all branches in this studio
  role_name   String // denormalized for quick access (e.g. "owner", "trainer")
  is_primary  Boolean  @default(false)
  assigned_by String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz()

  user UserIdentity @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, studio_id, branch_id])
  @@index([user_id])
  @@index([studio_id])
  @@index([user_id, studio_id])
  @@map("user_roles")
  @@schema("public")
}

model StaffInvitation {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studio_id            String    @db.Uuid
  staff_id             String    @db.Uuid
  email                String
  token                String    @unique
  role_name            String
  branch_id            String?   @db.Uuid
  permission_overrides Json      @default("{}")
  status               String    @default("pending") // pending | accepted | revoked | expired
  invited_by           String    @db.Uuid
  expires_at           DateTime  @db.Timestamptz()
  accepted_at          DateTime? @db.Timestamptz()
  created_at           DateTime  @default(now()) @db.Timestamptz()

  @@index([studio_id])
  @@index([staff_id])
  @@index([token])
  @@map("staff_invitations")
  @@schema("public")
}

// =============================================
// PER-STUDIO SCHEMA — Organization Hierarchy
// =============================================

model Organization {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id        String   @db.Uuid
  name          String
  slug          String   @unique
  logo_url      String?
  industry_type String   @default("fitness") // fitness | wellness | sports | rehabilitation
  country       String?
  timezone      String   @default("Asia/Kolkata")
  currency      String   @default("INR")
  status        String   @default("active") // active | suspended | inactive
  created_at    DateTime @default(now()) @db.Timestamptz()
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz()

  regions              Region[]
  branches             Branch[]
  settings             OrganizationSettings?
  franchise_owners     FranchiseOwner[]
  staff                Staff[]
  members              Member[]
  membership_plans     MembershipPlan[]
  corporate_accounts   CorporateAccount[]
  class_templates      ClassTemplate[]
  member_invoices      MemberInvoice[]
  product_categories   ProductCategory[]
  products             Product[]
  suppliers            Supplier[]
  message_templates    MessageTemplate[]
  automation_workflows AutomationWorkflow[]
  referral_programs    ReferralProgram[]
  leads                Lead[]
  daily_gym_metrics    DailyGymMetrics[]
  membership_analytics MembershipAnalytics[]
  revenue_analytics    RevenueAnalytics[]
  webhooks             Webhook[]
  integrations         Integration[]
  feature_flags_list   FeatureFlag[]
  white_label_config   WhiteLabelConfig?
  system_notifications SystemNotification[]

  @@index([status])
  @@map("organizations")
  @@schema("studio_template")
}

model OrganizationSettings {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id           String   @db.Uuid
  organization_id  String   @unique @db.Uuid
  default_timezone String   @default("Asia/Kolkata")
  default_currency String   @default("INR")
  billing_plan     String?
  feature_flags    Json     @default("{}")
  branding         Json     @default("{}") // { primary_color, logo_url, ... }
  created_at       DateTime @default(now()) @db.Timestamptz()
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("organization_settings")
  @@schema("studio_template")
}

model Region {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String   @db.Uuid
  organization_id String   @db.Uuid
  name            String
  country         String?
  timezone        String?
  manager_id      String?  @db.Uuid // references Staff.id or user_id
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  branches     Branch[]

  @@index([organization_id])
  @@map("regions")
  @@schema("studio_template")
}

// =============================================
// PER-STUDIO SCHEMA — Branch (Physical Location)
// =============================================

model Branch {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String   @db.Uuid
  organization_id String?  @db.Uuid
  region_id       String?  @db.Uuid
  name            String
  code            String?  @unique // e.g. "NYC-DT", "LA-CENT"
  address         String?
  city            String?
  state           String?
  country         String?
  postal_code     String?
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)
  phone           String?
  email           String?
  status          String   @default("active") // active | inactive | temporarily_closed | coming_soon
  is_active       Boolean  @default(true)
  opening_time    String? // "06:00" (HH:mm)
  closing_time    String? // "22:00" (HH:mm)
  timezone        String   @default("Asia/Kolkata") // IANA tz; per-branch date math (duplicate-window, opening hours)
  // ── GST overrides (fall back to studio.gstin / gst_state_code when null) ──
  gstin           String?
  gst_state_code  String?
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization             Organization?            @relation(fields: [organization_id], references: [id])
  region                   Region?                  @relation(fields: [region_id], references: [id])
  settings                 BranchSettings?
  branch_franchises        BranchFranchise[]
  staff_primary            Staff[]                  @relation("StaffPrimaryBranch")
  staff_attendance         StaffAttendance[]
  trainer_sessions         TrainerSession[]
  trainer_revenue          TrainerRevenue[]
  members                  Member[]
  membership_plans         MembershipPlan[]
  member_memberships       MemberMembership[]
  membership_branch_access MembershipBranchAccess[]
  check_ins                CheckIn[]
  classes                  Class[]
  class_templates          ClassTemplate[]
  class_sessions           ClassSession[]
  studios                  StudioRoom[]
  payments                 Payment[]
  expenses                 Expense[]
  member_invoices          MemberInvoice[]
  financial_transactions   FinancialTransaction[]
  staff_shifts             StaffShift[]
  products                 Product[]
  inventory                Inventory[]
  inventory_transactions   InventoryTransaction[]
  purchase_orders          PurchaseOrder[]
  pos_sales                PosSale[]
  product_batches          ProductBatch[]
  branch_product_prices    BranchProductPrice[]
  transfers_from           StockTransfer[]          @relation("TransferFrom")
  transfers_to             StockTransfer[]          @relation("TransferTo")
  bundles                  Bundle[]
  leads                    Lead[]
  daily_gym_metrics        DailyGymMetrics[]
  membership_analytics     MembershipAnalytics[]
  revenue_analytics        RevenueAnalytics[]
  class_analytics          ClassAnalytics[]
  trainer_analytics        TrainerAnalytics[]
  check_in_events          CheckInEvent[]
  check_in_devices         CheckInDevice[]
  dashboard_metrics        DashboardMetrics[]

  @@index([organization_id])
  @@index([region_id])
  @@index([status])
  @@map("branches")
  @@schema("studio_template")
}

model BranchSettings {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id             String   @db.Uuid
  branch_id          String   @unique @db.Uuid
  currency           String   @default("INR")
  tax_percentage     Decimal  @default(0) @db.Decimal(5, 2)
  membership_policy  Json     @default("{}") // { grace_period_days, freeze_limit, ... }
  checkin_policy     Json     @default("{}") // { allow_qr, allow_facial, allow_manual, ... }
  notification_prefs Json     @default("{}") // { sms_enabled, email_enabled, whatsapp_enabled }
  created_at         DateTime @default(now()) @db.Timestamptz()
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz()

  branch Branch @relation(fields: [branch_id], references: [id], onDelete: Cascade)

  @@map("branch_settings")
  @@schema("studio_template")
}

// =============================================
// PER-STUDIO SCHEMA — Franchise Support
// =============================================

model FranchiseOwner {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String   @db.Uuid
  organization_id String   @db.Uuid
  owner_name      String
  email           String
  phone           String?
  user_id         String?  @db.Uuid // linked Identity for dashboard access
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization      Organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  branch_franchises BranchFranchise[]

  @@index([organization_id])
  @@map("franchise_owners")
  @@schema("studio_template")
}

model BranchFranchise {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id             String    @db.Uuid
  branch_id          String    @db.Uuid
  franchise_owner_id String    @db.Uuid
  revenue_share_pct  Decimal?  @db.Decimal(5, 2)
  contract_start     DateTime? @db.Date
  contract_end       DateTime? @db.Date
  created_at         DateTime  @default(now()) @db.Timestamptz()

  branch          Branch         @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  franchise_owner FranchiseOwner @relation(fields: [franchise_owner_id], references: [id], onDelete: Cascade)

  @@unique([branch_id, franchise_owner_id])
  @@index([franchise_owner_id])
  @@map("branch_franchises")
  @@schema("studio_template")
}

model Member {
  id                      String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id                  String                      @db.Uuid
  member_code             String                      @unique
  organization_id         String?                     @db.Uuid
  branch_id               String                      @db.Uuid
  full_name               String
  phone                   String
  email                   String?
  gender                  String? // male | female | other | prefer_not_to_say
  date_of_birth           DateTime?                   @db.Date
  emergency_contact_name  String?
  emergency_contact_phone String?
  profile_photo_url       String?
  face_descriptor         Float[]
  face_vec                Unsupported("vector(128)")? // pgvector — indexed for 1:N facial matching; backfilled from face_descriptor
  checkin_method          String                      @default("manual")
  qr_code                 String?                     @unique
  qr_version              Int                         @default(1) // increments on regenerate; old signed tokens become invalid
  qr_regenerated_at       DateTime?                   @db.Timestamptz()
  status                  String                      @default("active") // lead | trial | active | inactive | cancelled | frozen | expiring_soon | expired
  engagement_score        Int                         @default(0)
  churn_risk              String                      @default("low") // low | medium | high
  referral_code           String?                     @unique
  referred_by_member_id   String?                     @db.Uuid
  notes                   String?
  join_date               DateTime?                   @db.Date
  last_visit_at           DateTime?                   @db.Timestamptz()
  created_at              DateTime                    @default(now()) @db.Timestamptz()
  updated_at              DateTime                    @default(now()) @updatedAt @db.Timestamptz()

