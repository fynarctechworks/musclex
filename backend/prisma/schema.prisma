  member Member @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([member_id, consent_type])
  @@index([created_at])
  @@map("consent_logs")
  @@schema("studio_template")
}

model DataRequest {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  member_id     String    @db.Uuid
  type          String // export | deletion
  format        String?   @default("json") // json | csv
  status        String    @default("pending") // pending | processing | completed | rejected
  reason        String?
  requested_by  String?   @db.Uuid
  processed_by  String?   @db.Uuid
  data_snapshot Json?
  completed_at  DateTime? @db.Timestamptz()
  created_at    DateTime  @default(now()) @db.Timestamptz()
  updated_at    DateTime  @updatedAt @db.Timestamptz()

