model WebhookDelivery {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  webhook_id      String    @db.Uuid
  event           String
  payload         Json
  response_status Int?
  response_body   String?
  attempt         Int       @default(1)
  status          String    @default("pending") // pending | delivered | failed
  delivered_at    DateTime? @db.Timestamptz()
  created_at      DateTime  @default(now()) @db.Timestamptz()

  webhook Webhook @relation(fields: [webhook_id], references: [id], onDelete: Cascade)

  @@index([webhook_id])
  @@index([status])
  @@index([created_at])
  @@map("webhook_deliveries")
  @@schema("studio_template")
}

model Integration {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  organization_id String    @db.Uuid
  provider        String // twilio | whatsapp | razorpay | stripe | resend | google_calendar | zapier
  display_name    String
  config          Json      @default("{}") // encrypted credentials & settings
  status          String    @default("inactive") // active | inactive | error | pending_setup
  is_enabled      Boolean   @default(false)
  last_synced_at  DateTime? @db.Timestamptz()
  error_message   String?
  metadata        Json      @default("{}") // provider-specific metadata
  created_by      String?   @db.Uuid
  created_at      DateTime  @default(now()) @db.Timestamptz()
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamptz()

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, provider])
  @@index([organization_id])
  @@index([provider])
  @@map("integrations")
  @@schema("studio_template")
}

model FeatureFlag {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  organization_id String   @db.Uuid
  key             String // e.g. "facial_recognition", "ai_advisor", "pos_module"
  is_enabled      Boolean  @default(false)
  description     String?
  metadata        Json     @default("{}") // conditions, rollout %, etc.
  created_at      DateTime @default(now()) @db.Timestamptz()
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, key])
  @@index([organization_id])
  @@map("feature_flags")
  @@schema("studio_template")
}

