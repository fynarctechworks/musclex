// =============================================
// PER-STUDIO SCHEMA — Class & Facility Scheduling
// =============================================

model ClassTemplate {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  organization_id          String?  @db.Uuid
  branch_id                String?  @db.Uuid
  name                     String
  description              String?
  category                 String // cardio | strength | flexibility | mind_body | dance | martial_arts | rehabilitation | other
  default_duration_minutes Int      @default(60)
  default_capacity         Int      @default(20)
  created_by_id            String?  @db.Uuid
  is_active                Boolean  @default(true)
  created_at               DateTime @default(now()) @db.Timestamptz()
  updated_at               DateTime @default(now()) @updatedAt @db.Timestamptz()

  organization    Organization?        @relation(fields: [organization_id], references: [id])
  branch          Branch?              @relation(fields: [branch_id], references: [id])
  created_by      Staff?               @relation("TemplateCreator", fields: [created_by_id], references: [id])
  sessions        ClassSession[]
  recurring_rules ClassRecurringRule[]
  class_analytics ClassAnalytics[]

  @@index([branch_id])
  @@index([category])
  @@map("class_templates")
  @@schema("studio_template")
}

model StudioRoom {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  branch_id           String   @db.Uuid
  name                String
  capacity            Int      @default(30)
  equipment_available String[]
  is_active           Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz()

  branch   Branch         @relation(fields: [branch_id], references: [id])
  sessions ClassSession[]

  @@index([branch_id])
  @@map("studio_rooms")
  @@schema("studio_template")
}

model ClassSession {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  template_id         String?  @db.Uuid
  branch_id           String   @db.Uuid
  trainer_id          String   @db.Uuid
  studio_id           String?  @db.Uuid
  name                String // denormalized from template for quick display
  category            String   @default("other")
  start_time          DateTime @db.Timestamptz()
  end_time            DateTime @db.Timestamptz()
  capacity            Int
  enrolled_count      Int      @default(0)
  waitlist_count      Int      @default(0)
  status              String   @default("scheduled") // scheduled | in_progress | completed | cancelled
  cancellation_reason String?
  created_at          DateTime @default(now()) @db.Timestamptz()
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz()

  template    ClassTemplate?      @relation(fields: [template_id], references: [id])
  branch      Branch              @relation(fields: [branch_id], references: [id])
  trainer     Staff               @relation("SessionTrainer", fields: [trainer_id], references: [id])
  studio      StudioRoom?         @relation(fields: [studio_id], references: [id])
  bookings    ClassBooking[]
  waitlist    ClassWaitlist[]
  attendance  ClassAttendance[]
  assignments TrainerAssignment[]

  @@index([branch_id, start_time])
  @@index([trainer_id, start_time])
  @@index([studio_id, start_time])
  @@index([template_id])
  @@index([status])
  @@map("class_sessions")
  @@schema("studio_template")
}

model ClassBooking {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  session_id          String    @db.Uuid
  member_id           String    @db.Uuid
  booking_status      String    @default("booked") // booked | cancelled | checked_in | no_show
  booked_at           DateTime  @default(now()) @db.Timestamptz()
  cancelled_at        DateTime? @db.Timestamptz()
  cancellation_reason String?
  attended            Boolean   @default(false)

  session ClassSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  member  Member       @relation(fields: [member_id], references: [id])

  @@unique([session_id, member_id])
  @@index([member_id])
  @@index([session_id, booking_status])
  @@map("class_bookings")
  @@schema("studio_template")
}

model ClassWaitlist {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  session_id String   @db.Uuid
  member_id  String   @db.Uuid
  position   Int
  joined_at  DateTime @default(now()) @db.Timestamptz()

  session ClassSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  member  Member       @relation(fields: [member_id], references: [id])

  @@unique([session_id, member_id])
  @@index([session_id, position])
  @@index([member_id])
  @@map("class_waitlists")
  @@schema("studio_template")
}

model TrainerAssignment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  trainer_id  String   @db.Uuid
  session_id  String   @db.Uuid
  role        String   @default("primary") // primary | substitute | assistant
  assigned_at DateTime @default(now()) @db.Timestamptz()

  trainer Staff        @relation(fields: [trainer_id], references: [id])
  session ClassSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@unique([trainer_id, session_id])
  @@index([trainer_id])
  @@map("trainer_assignments")
  @@schema("studio_template")
}

model ClassAttendance {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  session_id        String    @db.Uuid
  member_id         String    @db.Uuid
  check_in_time     DateTime? @db.Timestamptz()
  attendance_status String    @default("registered") // registered | present | late | no_show | cancelled
  created_at        DateTime  @default(now()) @db.Timestamptz()

  session ClassSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  member  Member       @relation(fields: [member_id], references: [id])

  @@unique([session_id, member_id])
  @@index([member_id])
  @@index([check_in_time])
  @@map("class_attendance")
  @@schema("studio_template")
}

model ClassRecurringRule {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  template_id      String    @db.Uuid
  days_of_week     Int[] // 0=Sun, 1=Mon ... 6=Sat
  start_time       String // "07:00" HH:mm
  duration_minutes Int       @default(60)
  trainer_id       String?   @db.Uuid
  studio_id        String?   @db.Uuid
  branch_id        String    @db.Uuid
  capacity         Int?
  repeat_until     DateTime? @db.Date
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now()) @db.Timestamptz()

  template ClassTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([template_id])
  @@map("class_recurring_rules")
  @@schema("studio_template")
}

// ── Legacy Class model (kept for backward compat with check-ins) ──

model Class {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  branch_id             String    @db.Uuid
  trainer_id            String    @db.Uuid
  substitute_trainer_id String?   @db.Uuid
  name                  String
  category              String
  room                  String?
  capacity              Int
  duration_minutes      Int
  starts_at             DateTime  @db.Timestamptz()
  recurrence_rule       String?
  recurrence_end_date   DateTime? @db.Date
  status                String    @default("scheduled")
  created_at            DateTime  @default(now()) @db.Timestamptz()

  branch             Branch            @relation(fields: [branch_id], references: [id])
  trainer            Staff             @relation("ClassTrainer", fields: [trainer_id], references: [id])
  substitute_trainer Staff?            @relation("ClassSubstitute", fields: [substitute_trainer_id], references: [id])
  check_ins          CheckIn[]
  enrollments        ClassEnrollment[]

  @@index([branch_id, starts_at])
  @@map("classes")
  @@schema("studio_template")
}

model ClassEnrollment {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  class_id          String   @db.Uuid
  member_id         String   @db.Uuid
  status            String   @default("enrolled")
  waitlist_position Int?
  enrolled_at       DateTime @default(now()) @db.Timestamptz()

  class  Class  @relation(fields: [class_id], references: [id])
  member Member @relation(fields: [member_id], references: [id])

  @@map("class_enrollments")
  @@schema("studio_template")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  name        String
  description String?
  permissions Json     @default("{}") // Legacy: kept for backward compat during migration
  is_system   Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz()

  staff            Staff[]
  role_permissions RolePermission[]

  @@unique([name])
  @@map("roles")
  @@schema("studio_template")
}

model RolePermission {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  role_id         String   @db.Uuid
  permission_code String // references Permission.code (cross-schema, no FK)
  created_at      DateTime @default(now()) @db.Timestamptz()

  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_code])
  @@index([role_id])
  @@map("role_permissions")
  @@schema("studio_template")
}

model Staff {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  user_id           String?   @db.Uuid
  organization_id   String?   @db.Uuid
  branch_id         String?   @db.Uuid
  branch_ids        String[]  @db.Uuid
  employee_code     String?   @unique
  full_name         String
  role              String
  role_id           String?   @db.Uuid
  job_title         String?
  employment_type   String    @default("full_time")
  phone             String
  email             String?
  specializations   String[]
  salary            Decimal?  @db.Decimal(10, 2)
  performance_score Int       @default(0)
  status            String    @default("active")
  is_active         Boolean   @default(true)
  joined_at         DateTime? @db.Date
  created_at        DateTime  @default(now()) @db.Timestamptz()
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamptz()

  organization          Organization?              @relation(fields: [organization_id], references: [id])
  primary_branch        Branch?                    @relation("StaffPrimaryBranch", fields: [branch_id], references: [id])
  custom_role           Role?                      @relation(fields: [role_id], references: [id])
  profile               StaffProfile?
  availability          StaffAvailability[]
  attendance            StaffAttendance[]
  trainer_clients       TrainerClient[]            @relation("TrainerToClients")
  trainer_sessions      TrainerSession[]           @relation("TrainerSessions")
  payroll_config        PayrollConfig?
  trainer_revenue       TrainerRevenue[]
  member_notes          MemberNote[]
  classes_as_trainer    Class[]                    @relation("ClassTrainer")
  classes_as_substitute Class[]                    @relation("ClassSubstitute")
  expenses_recorded     Expense[]
  campaigns_created     Campaign[]
  ai_conversations      AiConversation[]
  freeze_approvals      MembershipFreeze[]
  templates_created     ClassTemplate[]            @relation("TemplateCreator")
  session_trainer       ClassSession[]             @relation("SessionTrainer")
  trainer_assignments   TrainerAssignment[]
  refunds_processed     Refund[]                   @relation("RefundProcessor")
  shifts                StaffShift[]
  leave_requests        LeaveRequest[]
  leave_reviews         LeaveRequest[]             @relation("LeaveReviewer")
  payroll_records       PayrollRecord[]
  performance_records   TrainerPerformanceRecord[]
  pos_sales             PosSale[]
  returns_processed     ProductReturn[]            @relation("ReturnProcessor")
  leads_assigned        Lead[]                     @relation("LeadAssignedStaff")
  lead_activities       LeadActivity[]             @relation("LeadActivityStaff")
  trainer_analytics     TrainerAnalytics[]

  @@index([organization_id])
  @@index([branch_id])
  @@index([role_id])
  @@index([status])
