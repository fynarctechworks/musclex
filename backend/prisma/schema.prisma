model PosSale {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String   @db.Uuid
  branch_id       String   @db.Uuid
  member_id       String?  @db.Uuid
  staff_id        String   @db.Uuid
  invoice_number  String   @unique
  subtotal        Decimal  @db.Decimal(10, 2)
  tax_amount      Decimal  @default(0) @db.Decimal(10, 2)
  discount_amount Decimal  @default(0) @db.Decimal(10, 2)
  total_amount    Decimal  @db.Decimal(10, 2)
  payment_method  String // cash | card | upi | wallet
  status          String   @default("completed") // completed | refunded | partial_refund
  // GST split (intra-state CGST+SGST or inter-state IGST)
  cgst_amount     Decimal  @default(0) @db.Decimal(10, 2)
  sgst_amount     Decimal  @default(0) @db.Decimal(10, 2)
  igst_amount     Decimal  @default(0) @db.Decimal(10, 2)
  place_of_supply String? // 2-digit GST state code of buyer
  // Phase 4: loyalty + wallet on the sale
  points_earned   Int      @default(0)
  points_redeemed Int      @default(0)
  wallet_amount   Decimal  @default(0) @db.Decimal(10, 2) // portion paid from wallet balance
  created_at      DateTime @default(now()) @db.Timestamptz()

  branch  Branch          @relation(fields: [branch_id], references: [id])
  member  Member?         @relation(fields: [member_id], references: [id])
  staff   Staff           @relation(fields: [staff_id], references: [id])
  items   PosSaleItem[]
  returns ProductReturn[]

  @@index([branch_id, created_at])
  @@index([member_id])
  @@index([staff_id])
  @@index([invoice_number])
  @@index([status])
  @@map("pos_sales")
  @@schema("studio_template")
}

model PosSaleItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id      String   @db.Uuid
  sale_id     String   @db.Uuid
  product_id  String   @db.Uuid
  batch_id    String?  @db.Uuid // primary batch this line drew from (FIFO); multi-batch splits logged in inventory_transactions
  // Phase 5: when set, this line is one component of a bundle sale; all component
  // rows from the same sale share a bundle_id. unit_price is the proportional split
  // of the bundle's own price (sum of split prices == bundle price).
  bundle_id   String?  @db.Uuid
  quantity    Int
  unit_price  Decimal  @db.Decimal(10, 2)
  tax_amount  Decimal  @default(0) @db.Decimal(10, 2)
  total_price Decimal  @db.Decimal(10, 2)
  // GST split fields (mirrors invoice_items)
  hsn_sac     String?
  tax_rate    Decimal  @default(0) @db.Decimal(5, 2)
  cgst_amount Decimal  @default(0) @db.Decimal(10, 2)
  sgst_amount Decimal  @default(0) @db.Decimal(10, 2)
  igst_amount Decimal  @default(0) @db.Decimal(10, 2)
  created_at  DateTime @default(now()) @db.Timestamptz()

  sale    PosSale       @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [product_id], references: [id])
  batch   ProductBatch? @relation(fields: [batch_id], references: [id])
  bundle  Bundle?       @relation(fields: [bundle_id], references: [id])

  @@index([sale_id])
  @@index([product_id])
  @@index([bundle_id])
  @@map("pos_sale_items")
  @@schema("studio_template")
}

