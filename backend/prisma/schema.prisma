model Expense {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id               String   @db.Uuid
  branch_id            String   @db.Uuid
  // Legacy slug retained for backward-compat reads; category_id is the new FK.
  category             String
  category_id          String?  @db.Uuid
  description          String
  amount               Decimal  @db.Decimal(10, 2)
  currency             String   @default("INR")
  expense_date         DateTime @db.Date
  receipt_url          String?
  vendor               String?
  notes                String?
  payment_method       String   @default("cash") // cash | card | upi | bank_transfer | razorpay | stripe
  // confirmed | reversed — reversals are appended as new rows; the original is flipped to "reversed".
  status               String   @default("confirmed")
  // For a reversal row, points at the original expense it reverses (null on originals).
  reference_id         String?  @db.Uuid
  // Partial-unique with gym_id for safe retry/idempotent create.
  idempotency_key      String?
  recorded_by_staff_id String   @db.Uuid
  created_at           DateTime @default(now()) @db.Timestamptz()

  branch       Branch           @relation(fields: [branch_id], references: [id])
  recorded_by  Staff            @relation(fields: [recorded_by_staff_id], references: [id])
  category_ref ExpenseCategory? @relation(fields: [category_id], references: [id])
  // Self-relation for the immutable reversal ledger.
  reversal_of  Expense?         @relation("ExpenseReversal", fields: [reference_id], references: [id])
  reversed_by  Expense[]        @relation("ExpenseReversal")

  @@unique([gym_id, idempotency_key], name: "gym_id_idempotency_key")
  @@index([branch_id, expense_date])
  @@index([category_id])
  @@index([status])
  @@map("expenses")
  @@schema("studio_template")
}

model ExpenseCategory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id     String   @db.Uuid
  // null = gym-wide category; set = branch-specific override.
  branch_id  String?  @db.Uuid
  name       String
  slug       String
  icon       String?
  color      String?
  is_default Boolean  @default(false)
  is_active  Boolean  @default(true)
  sort_order Int      @default(50)
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

