// =============================================================
// Wave 15 — Enterprise Check-In Module
// =============================================================
// Append-only event log for every check-in attempt (success, denial,
// override, duplicate). CheckIn (legacy) becomes a read-side projection
// kept in sync by a projector until callers migrate.
//
// outcome:        success | denied | overridden | duplicate
// method:         qr_static | qr_dynamic | manual | facial | fingerprint | rfid | kiosk_search | override
// source:         staff_desktop | kiosk | mobile_app | turnstile | api | offline_sync
//
// Idempotency: (gym_id, client_event_id) is UNIQUE — offline replays
// land as duplicates without double-writing.

model CheckInEvent {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String   @db.Uuid
  member_id           String   @db.Uuid
  membership_id       String?  @db.Uuid
  branch_id           String   @db.Uuid
  class_id            String?  @db.Uuid
  device_id           String?  @db.Uuid
  client_event_id     String   @db.Uuid
  method              String
  source              String
  outcome             String
  denial_reason       String?
  override_reason     String?
  override_by_user_id String?  @db.Uuid
  qr_token_jti        String?
  policy_snapshot     Json     @default("{}")
  rule_trace          Json     @default("[]")
  ip_address          String?
  user_agent          String?
  recorded_at         DateTime @default(now()) @db.Timestamptz()
  created_at          DateTime @default(now()) @db.Timestamptz()

  member Member         @relation(fields: [member_id], references: [id])
  branch Branch         @relation(fields: [branch_id], references: [id])
  device CheckInDevice? @relation(fields: [device_id], references: [id])

  @@unique([gym_id, client_event_id])
  @@index([branch_id, recorded_at(sort: Desc)])
  @@index([member_id, recorded_at(sort: Desc)])
  @@index([outcome, recorded_at(sort: Desc)])
  @@index([device_id, recorded_at(sort: Desc)])
  @@map("check_in_events")
  @@schema("studio_template")
}

// Kiosk / turnstile / hardware-scanner registry. A device is bound to a
// single branch and authenticates via a hashed device_secret presented at
// POST /api/v1/check-ins/device/{id}/scan.
//
// kind:   ipad_kiosk | android_kiosk | web_kiosk | turnstile | usb_fingerprint | other
// status: active | disabled | lost

model CheckInDevice {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id        String    @db.Uuid
  branch_id     String    @db.Uuid
  device_name   String
  kind          String
  hardware_id   String?
  device_secret String // bcrypt hashed
  pin_hash      String // 4–6 digit staff PIN to exit kiosk mode
  status        String    @default("active")
  last_seen_at  DateTime? @db.Timestamptz()
  registered_by String    @db.Uuid
  registered_at DateTime  @default(now()) @db.Timestamptz()
  created_at    DateTime  @default(now()) @db.Timestamptz()
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz()

  branch          Branch         @relation(fields: [branch_id], references: [id])
  check_in_events CheckInEvent[]

  @@index([branch_id, status])
  @@index([gym_id])
  @@map("check_in_devices")
  @@schema("studio_template")
}

// Replay-protection audit for signed QR tokens. The `jti` is the unique
// id baked into the signed payload (dynamic) or hash(token) (static).
// We SETEX in Redis for fast denial; this table is the durable forensic
// trail.

model QrTokenAudit {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id     String   @db.Uuid
  jti        String   @unique
  member_id  String   @db.Uuid
  qr_version Int
  token_kind String // 'static' | 'dynamic'
