  payment_method_token String?
  created_at           DateTime  @default(now()) @db.Timestamptz()
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz()

  member            Member             @relation(fields: [member_id], references: [id])
  plan              MembershipPlan     @relation(fields: [plan_id], references: [id])
  branch            Branch             @relation(fields: [branch_id], references: [id])
  check_ins         CheckIn[]
  payments          Payment[]
  freezes           MembershipFreeze[]
  family_membership FamilyMembership?
  corporate_members CorporateMember[]

  @@index([member_id, status])
  @@index([status, end_date])
  @@index([auto_renew, status])
  @@map("member_memberships")
  @@schema("studio_template")
}

