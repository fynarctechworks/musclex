  used_at    DateTime @default(now()) @db.Timestamptz()
  created_at DateTime @default(now()) @db.Timestamptz()

  member Member @relation(fields: [member_id], references: [id])

  @@index([member_id, used_at(sort: Desc)])
  @@index([gym_id, used_at(sort: Desc)])
  @@map("qr_token_audits")
  @@schema("studio_template")
}

// Biometric enrollment registry. Separates the act of enrollment (with
// consent + audit) from the storage of the biometric template itself.
// Face descriptors today live on members.face_vec; future fingerprint
