// =============================================
// REFERRAL & GROWTH ENGINE — Phase 1 Foundation
// =============================================
//
// Two parallel systems share these tables:
//   • SaaS → Gym (B2B): Studio referrals, SaaS-admin-controlled policies
//   • Gym  → Member (B2C): handled by separate studio_template models below
//
// Design rules:
//   • Referrals are EVENT systems, not coupon fields.
//   • RewardLog is APPEND-ONLY (immutable financial audit trail).
//   • All state transitions logged in ReferralLifecycleEvent.
//   • Policies live in ReferralRewardRule (conditions+rewards JSONB).
//   • Wallet is a separate ledger (ReferralWalletEntry append-only).
//   • Idempotency keys prevent double-rewarding on retries/replays.

// ── Lifecycle status enums (string for forward compat) ───────────────
// Referral.status:
//   pending → invited → registered → trial_started → subscribed
//          → payment_verified → reward_pending → rewarded
//          [ → reversed | fraud | expired ]

model Referral {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referrer_studio_id String    @db.Uuid
  referred_studio_id String    @unique @db.Uuid // a studio can only be referred once
  referral_code      String // immutable snapshot of the code used
  referred_email     String?
  campaign_id        String?   @db.Uuid // optional time-bounded campaign attribution
  status             String    @default("pending") // see lifecycle above
  risk_score         Int       @default(0) // 0–100; computed by fraud engine
  rewarded_at        DateTime? @db.Timestamptz()
  reversed_at        DateTime? @db.Timestamptz()
  reversed_reason    String?
  idempotency_key    String?   @unique // set once reward processing begins
  metadata           Json      @default("{}") // utm, device, ip, etc.
  created_at         DateTime  @default(now()) @db.Timestamptz()
  updated_at         DateTime  @default(now()) @updatedAt @db.Timestamptz()

  referrer_studio Studio                   @relation("ReferrerStudio", fields: [referrer_studio_id], references: [id])
  referred_studio Studio                   @relation("ReferredStudio", fields: [referred_studio_id], references: [id])
  campaign        ReferralCampaign?        @relation(fields: [campaign_id], references: [id])
  reward_logs     RewardLog[]
  lifecycle       ReferralLifecycleEvent[]
  fraud_signals   ReferralFraudSignal[]

  @@index([referrer_studio_id])
  @@index([status])
  @@index([referral_code])
  @@index([campaign_id])
  @@map("referrals")
  @@schema("public")
}

// SaaS-admin-controlled policy engine.
// conditions/rewards are JSONB so policies evolve without migrations.
model ReferralRewardRule {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  description   String?
  // 'b2b_subscription_activated' | 'b2b_subscription_renewed' | 'b2b_yearly_upgrade' | ...
  trigger_event String    @default("b2b_subscription_activated")
  campaign_id   String?   @db.Uuid
  conditions    Json      @default("{}")
  rewards       Json      @default("[]")
  priority      Int       @default(0)
  is_active     Boolean   @default(true)
  max_uses      Int?
  uses_count    Int       @default(0)
  valid_from    DateTime? @db.Timestamptz()
  valid_until   DateTime? @db.Timestamptz()
  created_by    String?   @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamptz()
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz()

  campaign    ReferralCampaign? @relation(fields: [campaign_id], references: [id])
  reward_logs RewardLog[]

  @@index([is_active, trigger_event])
  @@index([priority])
  @@index([campaign_id])
  @@map("referral_reward_rules")
  @@schema("public")
}

// Immutable, append-only financial audit log.
// Never UPDATE rows here except to flip status to 'reversed'.
model RewardLog {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referral_id                String    @db.Uuid
  rule_id                    String    @db.Uuid
  beneficiary_studio_id      String    @db.Uuid
  event_type                 String // 'subscription_activated' | 'subscription_renewed' | ...
  event_payload              Json // full payload snapshot at award time
  reward_type                String // 'extend_subscription' | 'account_credit' | 'trial_extension' | 'wallet_credit'
  reward_value               Json // shape depends on reward_type
  idempotency_key            String    @unique
  status                     String    @default("applied") // applied | failed | reversed
  failure_reason             String?
  // Snapshot of subscription extension for audit
  subscription_extended_from DateTime? @db.Timestamptz()
  subscription_extended_to   DateTime? @db.Timestamptz()
  applied_at                 DateTime  @default(now()) @db.Timestamptz()
  reversed_at                DateTime? @db.Timestamptz()
  reversed_reason            String?

  referral    Referral           @relation(fields: [referral_id], references: [id])
  rule        ReferralRewardRule @relation(fields: [rule_id], references: [id])
  beneficiary Studio             @relation("RewardBeneficiary", fields: [beneficiary_studio_id], references: [id])

  @@index([beneficiary_studio_id, status])
  @@index([referral_id])
  @@index([applied_at])
  @@map("reward_logs")
  @@schema("public")
}

// Append-only state transition log. Never updated, only inserted.
model ReferralLifecycleEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referral_id String   @db.Uuid
  from_status String?
  to_status   String
  actor_type  String   @default("system") // system | admin | webhook | gym_owner
  actor_id    String?  @db.Uuid
  payload     Json     @default("{}")
  occurred_at DateTime @default(now()) @db.Timestamptz()

  referral Referral @relation(fields: [referral_id], references: [id])

  @@index([referral_id, occurred_at])
  @@map("referral_lifecycle_events")
  @@schema("public")
}

// Risk signals — never auto-ban; surface to admin review queue.
model ReferralFraudSignal {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referral_id       String?   @db.Uuid // null = signal not yet bound to a referral
  subject_studio_id String?   @db.Uuid // either subject studio
  signal_type       String // 'duplicate_phone' | 'duplicate_gst' | 'duplicate_ip' | 'self_referral' | 'velocity' | 'device_fingerprint'
  severity          String    @default("low") // low | medium | high | critical
  evidence          Json      @default("{}") // raw matching data
  review_status     String    @default("pending") // pending | reviewed_ok | confirmed_fraud
  reviewed_by       String?   @db.Uuid
  reviewed_at       DateTime? @db.Timestamptz()
  reviewer_notes    String?
  created_at        DateTime  @default(now()) @db.Timestamptz()

  referral Referral? @relation(fields: [referral_id], references: [id])
  subject  Studio?   @relation("FraudSubjectStudio", fields: [subject_studio_id], references: [id])

  @@index([review_status, severity])
  @@index([subject_studio_id])
  @@map("referral_fraud_signals")
  @@schema("public")
}

// One wallet per studio. Balance is DERIVED from sum of wallet_entries —
// never stored as a mutable field. This guarantees immutability + audit.
model ReferralWallet {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studio_id  String   @unique @db.Uuid
  currency   String   @default("INR")
  // Cached balance — recomputed by trigger / app code from entries.
  // Authoritative source is the SUM of entries.
  balance    Decimal  @default(0) @db.Decimal(14, 2)
  status     String   @default("active") // active | frozen
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  studio  Studio                @relation(fields: [studio_id], references: [id])
  entries ReferralWalletEntry[]

  @@map("referral_wallets")
  @@schema("public")
}

// Append-only ledger. Positive = credit, negative = debit.
// Never UPDATE or DELETE — reversals are NEW entries with reverses_entry_id set.
model ReferralWalletEntry {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet_id         String    @db.Uuid
  entry_type        String // 'credit' | 'debit' | 'reversal' | 'expiry'
  amount            Decimal   @db.Decimal(14, 2) // signed
  currency          String    @default("INR")
  source_type       String // 'referral_reward' | 'manual_adjustment' | 'subscription_payment' | 'addon_purchase' | 'expiry'
  source_id         String?   @db.Uuid // FK target depends on source_type
  reward_log_id     String?   @db.Uuid
  reverses_entry_id String?   @db.Uuid
  idempotency_key   String    @unique
  expires_at        DateTime? @db.Timestamptz() // credits can expire
  description       String?
  metadata          Json      @default("{}")
  created_at        DateTime  @default(now()) @db.Timestamptz()

  wallet ReferralWallet @relation(fields: [wallet_id], references: [id])

  @@index([wallet_id, created_at])
  @@index([source_type, source_id])
  @@map("referral_wallet_entries")
  @@schema("public")
}

// Time-bounded campaigns (e.g. Summer 2026, Festival Offer).
// A campaign's rule_overrides JSON can boost rewards for the duration.
model ReferralCampaign {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String?
  scope          String    @default("global") // global | region | plan
  scope_filters  Json      @default("{}") // { regions: [...], plan_ids: [...] }
  rule_overrides Json      @default("[]") // RewardAction[] to apply on top of base rules
  valid_from     DateTime? @db.Timestamptz()
  valid_until    DateTime? @db.Timestamptz()
  is_active      Boolean   @default(true)
  max_total_uses Int?
  uses_count     Int       @default(0)
  created_by     String?   @db.Uuid
  created_at     DateTime  @default(now()) @db.Timestamptz()
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamptz()

  referrals Referral[]
  rules     ReferralRewardRule[]

  @@index([is_active, valid_from, valid_until])
  @@map("referral_campaigns")
  @@schema("public")
}

// =============================================
// PER-STUDIO B2C REFERRAL — Gym → Member
// =============================================
// Extends existing MemberReferral + ReferralProgram with lifecycle + immutable rewards.

// Append-only lifecycle events for member referrals.
model MemberReferralEvent {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id             String   @db.Uuid
  member_referral_id String   @db.Uuid
  from_status        String?
  to_status          String // link_shared | code_used | member_registered | payment_completed | active_membership | reward_unlocked | reward_claimed | cancelled
  actor_type         String   @default("system")
  actor_id           String?  @db.Uuid
  payload            Json     @default("{}")
  occurred_at        DateTime @default(now()) @db.Timestamptz()

  @@index([member_referral_id, occurred_at])
  @@index([gym_id])
  @@map("member_referral_events")
  @@schema("studio_template")
}

// Immutable reward log per member referral.
model MemberReferralReward {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id                String    @db.Uuid
  member_referral_id    String    @db.Uuid
  program_id            String?   @db.Uuid // FK to ReferralProgram
  beneficiary_member_id String    @db.Uuid // who gets the reward (usually the referrer)
  reward_type           String // 'free_days' | 'wallet_credit' | 'pt_session' | 'merchandise' | 'plan_upgrade' | 'discount'
  reward_value          Json
  status                String    @default("applied") // applied | claimed | expired | reversed
  idempotency_key       String    @unique
  applied_at            DateTime  @default(now()) @db.Timestamptz()
  claimed_at            DateTime? @db.Timestamptz()
  expires_at            DateTime? @db.Timestamptz()
  reversed_at           DateTime? @db.Timestamptz()
  reversed_reason       String?
  notes                 String?

  @@index([gym_id, status])
  @@index([beneficiary_member_id])
  @@index([member_referral_id])
  @@map("member_referral_rewards")
  @@schema("studio_template")
}

// Per-gym fraud signals for member referrals.
model MemberReferralFraudSignal {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id             String    @db.Uuid
  member_referral_id String?   @db.Uuid
  subject_member_id  String?   @db.Uuid
  signal_type        String // duplicate_phone | duplicate_email | duplicate_device | self_referral | velocity | biometric_match
  severity           String    @default("low")
  evidence           Json      @default("{}")
  review_status      String    @default("pending")
  reviewed_by        String?   @db.Uuid
  reviewed_at        DateTime? @db.Timestamptz()
  reviewer_notes     String?
  created_at         DateTime  @default(now()) @db.Timestamptz()

  @@index([gym_id, review_status])
  @@map("member_referral_fraud_signals")
  @@schema("studio_template")
}
