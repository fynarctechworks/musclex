// AUTO-GENERATED by scripts/_phase2_split.js — do not hand-edit yet.
generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client-public"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Studio {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  slug                    String    @unique
  schema_name             String    @unique
  owner_user_id           String    @db.Uuid
  logo_url                String?
  tagline                 String?
  phone                   String?
  email                   String?
  website                 String?
  address                 String?
  city                    String?
  state                   String?
  country                 String?
  postal_code             String?
  business_name           String?
  business_type           String?
  timezone                String    @default("Asia/Kolkata")
  currency                String    @default("INR")
  subscription_plan       String    @default("free")
  subscription_status     String    @default("trial")
  billing_cycle           String    @default("monthly")
  billing_name            String?
  billing_email           String?
  billing_address         String?
  tax_id                  String?
  subscription_start      DateTime? @db.Timestamptz()
  next_billing_date       DateTime? @db.Timestamptz()
  trial_ends_at           DateTime? @db.Timestamptz()
  subscription_expires_at DateTime? @db.Timestamptz() // hard expiry; reward engine extends this
  // ── Subscription lifecycle (computed by SubscriptionPolicyService) ──
  // active | grace_period | locked | suspended
  lifecycle_status        String    @default("active")
  grace_until             DateTime? @db.Timestamptz() // last second of grace; null when ACTIVE
  locked_at               DateTime? @db.Timestamptz() // when LOCKED transition happened
  suspended_at            DateTime? @db.Timestamptz() // manual admin suspension
  last_status_computed_at DateTime? @db.Timestamptz()
  last_login_at           DateTime? @db.Timestamptz()
  two_factor_enabled      Boolean   @default(false)
  email_verified          Boolean   @default(false)
  phone_verified          Boolean   @default(false)
  account_type            String    @default("gym")
  // ── GST / tax-invoice settings (India) ──
  gstin                   String?
  gst_state_code          String? // 2-digit numeric, e.g. "27" for Maharashtra
  default_hsn             String?
  invoice_prefix          String?
  invoice_terms           String?
  referral_code           String    @unique
  referred_by_code        String?
  referral_free_days      Int       @default(0)
  referral_reward_days    Int       @default(0)
  created_at              DateTime  @default(now()) @db.Timestamptz()
  updated_at              DateTime  @default(now()) @updatedAt @db.Timestamptz()

  invoices            Invoice[]
  subscription_events SubscriptionEvent[]
  member_directory    MemberDirectory[]

  // ── Referral & Growth Engine relations ──
  referrals_sent    Referral[]            @relation("ReferrerStudio")
  referral_received Referral?             @relation("ReferredStudio")
  reward_logs       RewardLog[]           @relation("RewardBeneficiary")
  referral_wallet   ReferralWallet?
  fraud_signals     ReferralFraudSignal[] @relation("FraudSubjectStudio")

  @@index([lifecycle_status])
  @@index([next_billing_date])
  @@index([grace_until])
  @@index([subscription_expires_at])
  @@map("studios")
}

model MemberDirectory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone      String // E.164
  tenant_id  String   @db.Uuid // Studio UUID — drives gym_id scoping
  member_id  String   @db.Uuid // PK of members row inside studio_template
  status     String   @default("active") // active | inactive
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  studio Studio @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([phone, tenant_id])
  @@unique([tenant_id, member_id])
  @@index([phone])
  @@map("member_directory")
}

model MemberRefreshToken {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_user_id String?   @db.Uuid // canonical person; null only for legacy pre-cutover rows
  member_id   String?   @db.Uuid // null for gym-less public users
  tenant_id   String?   @db.Uuid // Studio UUID; null for gym-less public users
  token_hash  String    @unique // sha256(refreshToken)
  expires_at  DateTime  @db.Timestamptz()
  revoked_at  DateTime? @db.Timestamptz()
  replaced_by String?   @db.Uuid // rotation chain — id of the token that superseded this one
  created_at  DateTime  @default(now()) @db.Timestamptz()

  @@index([member_id, tenant_id])
  @@index([app_user_id])
  @@map("member_refresh_tokens")
}

model AppUser {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone            String    @unique // E.164 — the login key (proved via OTP)
  full_name        String?
  email            String?
  city             String?
  gender           String? // male | female | other | prefer_not_to_say
  date_of_birth    DateTime? @db.Date
  referral_source  String? // how they found the app (organic | referral | campaign | ...)
  referral_code    String?   @unique // this person's own code to share (Phase 5c)
  referred_by_app_user_id String? @db.Uuid // the app_user who referred them
  // ── Fitness profile (Phase 7.1) — gym-less counterpart of member_profiles.
  //    Current weight is NOT stored here; it's the latest app_user_weight_logs row.
  height_cm           Decimal? @db.Decimal(5, 1)
  height_unit         String?  @default("cm") // cm | ft
  weight_unit         String?  @default("kg") // kg | lb
  primary_goal        String?
  fitness_goals       Json     @default("[]") @map("goals") // onboarding goal multi-select; DB col is `goals`
  activity_level      String?
  training_experience String?
  workout_preferences Json     @default("[]")
  limitations         Json     @default("[]")
  onboarding_step     String? // resume marker for the onboarding flow
  onboarding_state String    @default("not_started") // not_started | in_progress | completed
  status           String    @default("active") // active | inactive
  created_at       DateTime  @default(now()) @db.Timestamptz()
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamptz()
  last_active_at   DateTime? @db.Timestamptz()

  gym_links     AppUserGymLink[]
  weight_logs   AppUserWeightLog[]
  water_logs    AppUserWaterLog[]
  goals         AppUserGoal[]
  health_daily  AppUserHealthDaily[]
  events        AppUserEvent[]
  device_tokens AppUserDeviceToken[]
  deliveries    AppCampaignDelivery[]

  @@index([city])
  @@index([status])
  @@index([last_active_at])
  @@index([created_at])
  @@map("app_users")
}

model AppUserGymLink {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_user_id String   @db.Uuid
  tenant_id   String   @db.Uuid // Studio UUID
  member_id   String   @db.Uuid // members row inside studio_template
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz()

