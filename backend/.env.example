# Database — Session mode pooler (port 5432) for Prisma compatibility
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres"

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-jwt-secret-change-in-production

# App
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Resend email service
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=MuscleX <noreply@yourdomain.com>

# Anthropic AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Meta WhatsApp
META_WA_PHONE_NUMBER_ID=your-phone-number-id
META_WA_ACCESS_TOKEN=your-access-token
META_WA_VERIFY_TOKEN=your-verify-token

# ── Redis (Upstash) ────────────────────────────────────────────
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Optional Services ──────────────────────────────────────────
ENABLE_REDIS=false
ENABLE_SEARCH=false

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-api-key
