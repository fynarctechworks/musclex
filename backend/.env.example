# Database — Session mode pooler (port 5432) for Prisma compatibility
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres"

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
# Required at boot (main.ts). HASH_SECRET keys internal hashing; TWO_FACTOR_ENCRYPTION_KEY
# (required in production) encrypts stored TOTP secrets.
HASH_SECRET=your-hash-secret-change-in-production
TWO_FACTOR_ENCRYPTION_KEY=your-32-byte-2fa-encryption-key

# Member BFF (mobile app) — separate signing key + audience from admin/Supabase tokens.
# Member access tokens are signed with this secret and carry aud=member; admin
# tokens (verified against SUPABASE_JWT_SECRET) can never authorize /member/*.
MEMBER_JWT_SECRET=your-member-jwt-secret-change-in-production
MEMBER_ACCESS_TTL_SECONDS=900

# App
PORT=4000
NODE_ENV=development
# ⚠️ DEV-ONLY member OTP bypass. When set AND NODE_ENV!=production, the member app
# can log in with this fixed code instead of a real SMS OTP. Hard-disabled in
# production regardless of this value. Leave blank/unset to turn off.
MEMBER_DEV_OTP=
# 3000/3001 = admin SaaS web. Add 8081 + 19006 (and your LAN IP on those ports)
# when running the Expo member app on web — the browser blocks BFF calls otherwise.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081,http://localhost:19006
# Canonical URL of the gym/studio web app — used to build verification &
# password-reset links. Must point at the gym app, NOT the SaaS Control Center.
FRONTEND_URL=http://localhost:3001

# ── Email (Resend) ─────────────────────────────────────────────
# All transactional email routes through the centralized EmailService
# (backend/src/email). Without RESEND_API_KEY the NoopEmailProvider logs
# messages instead of sending (dev/CI) and never leaks links to clients.
# RESEND_FROM_EMAIL MUST be an address on a domain verified in Resend
# (see docs/email-infrastructure/DNS_SETUP.md for SPF/DKIM/DMARC).
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=MuscleX <noreply@mail.yourdomain.com>
# Optional default Reply-To (a real, monitored inbox).
EMAIL_REPLY_TO=support@yourdomain.com

# Anthropic AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Required in production; set to the secret configured on the Razorpay dashboard webhook.
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Meta WhatsApp
META_WA_PHONE_NUMBER_ID=your-phone-number-id
META_WA_ACCESS_TOKEN=your-access-token
META_WA_VERIFY_TOKEN=your-verify-token

# ── Redis (Upstash) ────────────────────────────────────────────
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Optional Services ──────────────────────────────────────────
ENABLE_REDIS=false
ENABLE_SEARCH=false

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-api-key
